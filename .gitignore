# pubspec.lock files generated by `dart pub get` in e2e dirs that only use
# local path deps (no pub packages). These pubspec.yaml files exist solely to
# satisfy the Dart analyzer in the IDE — the locks are trivial and not used by
# Bazel. e2e/pub_lock/ and e2e/dart_test_pkg/ locks ARE tracked because
# pub.from_lock() reads them at build time.
e2e/dart_test/pubspec.lock
e2e/library_deps/pubspec.lock
e2e/gazelle/pubspec.lock
e2e/pub_deps/pubspec.lock
e2e/web_app/pubspec.lock
